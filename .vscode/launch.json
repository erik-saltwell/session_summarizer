{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "-transcribe",
            "type": "debugpy",
            "request": "launch",
            "module": "session_summarizer",
            "console": "integratedTerminal",
            "args": [
                "transcribe",
                "--session",
                "test",
            ]
        },
        {
            "name": "-clean",
            "type": "debugpy",
            "request": "launch",
            "module": "session_summarizer",
            "console": "integratedTerminal",
            "args": [
                "clean",
                "--session",
                "test",
            ]
        },
        {
            "name": "-gen-settings",
            "type": "debugpy",
            "request": "launch",
            "module": "session_summarizer",
            "console": "integratedTerminal",
            "args": [
                "generate-sample-settings",
            ]
        },
        {
            "name": "-register",
            "type": "debugpy",
            "request": "launch",
            "module": "session_summarizer",
            "console": "integratedTerminal",
            "args": [
                "register-speakers",
                "--speaker-name",
                "andrew",
            ]
        },
        {
            "name": "custom args",
            "type": "debugpy",
            "request": "launch",
            "module": "session_summarizer",
            "console": "integratedTerminal",
            "args": "${command:pickArgs}"
        },
        {
            "name": "Integration Tests",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "justMyCode": true,
            "args": [
                "-s",
                "tests/integration"
            ],
            "console": "integratedTerminal"
        }
    ]
}
